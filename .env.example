# Copy to .env (gitignored) and fill in.

# ElevenLabs API key — used to create/patch agents and tools and to run agent tests.
ELEVENLABS_API_KEY=

# Shared webhook secret between the ElevenLabs tools and the deployed tool server
# (sent as the X-Tool-Secret header; set as an env var on the Cloud Run service).
# Generate with:  openssl rand -hex 32
TOOL_WEBHOOK_SECRET=
