{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(python3 *)",
      "Bash(pip install *)",
      "Bash(pip list*)",
      "Bash(ruff *)",
      "Bash(pytest *)",
      "Bash(uvicorn *)",
      "Bash(curl *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(git push*)",
      "Bash(rtk git status)",
      "Bash(rtk git diff *)",
      "Bash(rtk git log *)",
      "Bash(rtk git show *)",
      "Bash(rtk git branch *)",
      "Bash(rtk git add *)",
      "Bash(rtk git commit *)",
      "Bash(rtk git push*)",
      "Bash(rtk pytest *)",
      "Bash(rtk pip install *)",
      "Bash(rtk ls *)",
      "Bash(rtk find *)",
      "Bash(rtk read *)",
      "Bash(rtk grep *)",
      "Bash(rtk wc *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)"
    ],
    "ask": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; case \"$f\" in *.py) ruff format \"$f\" && ruff check --fix \"$f\";; esac; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
